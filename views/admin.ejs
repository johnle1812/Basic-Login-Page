<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin | Basic Login Page</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="home-page">
    <main class="home-shell">
      <section class="home-card admin-card">
        <p class="eyebrow">Admin Area</p>
        <h1>Welcome back, <%= username %>.</h1>
        <p class="hero-copy">
          This section is protected by JWT-based authentication and role checks.
          Only users whose MongoDB `role` is set to `admin` can reach this page.
        </p>
        <div class="detail-grid">
          <article>
            <span>Current role</span>
            <p><%= role %></p>
          </article>
          <article>
            <span>Access rule</span>
            <p>Verified token plus admin role required.</p>
          </article>
        </div>
        <div class="home-actions">
          <a class="button-link" href="/home">Back to home</a>
          <form action="/logout" method="post" class="inline-form">
            <button type="submit" class="button-link button-link-secondary">
              Log out
            </button>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
